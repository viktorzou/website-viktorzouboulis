---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => {
    if (a.data.pinned !== b.data.pinned) return a.data.pinned ? -1 : 1;
    return b.data.pubDate.getTime() - a.data.pubDate.getTime();
  });
---

<Layout title="Blog — Viktor Zouboulis">
  <section class="page-wrap py-16 sm:py-20">
    <p class="section-label mb-4">04 — blog</p>
    <h1 class="text-3xl font-medium text-ink sm:text-4xl dark:text-paper">Blog</h1>
    <p class="mt-4 max-w-xl text-base leading-relaxed text-muted">
      Notes on computational immunology, research, and adjacent ideas.
    </p>

    <div class="rule mt-12"></div>

    {posts.length > 0 ? (
      <ul class="mt-0">
        {posts.map((post) => (
          <li
            class:list={[
              "border-b border-ink/10 py-6 first:border-t dark:border-paper/10",
              post.data.pinned && "is-pinned",
            ]}
          >
            <div class="flex flex-col gap-2 sm:flex-row sm:items-baseline sm:justify-between sm:gap-12">
              <div class="min-w-0 flex-1">
                {post.data.pinned && <p class="section-label mb-2">pinned</p>}
                <h2 class="text-base font-medium text-ink dark:text-paper">
                  <a href={`/blog/${post.id}/`} class="hover:text-accent">
                    {post.data.title}
                  </a>
                </h2>
                {post.data.description && (
                  <p class="mt-2 text-sm leading-relaxed text-muted">{post.data.description}</p>
                )}
              </div>
              <time class="w-28 shrink-0 text-sm text-muted sm:text-right" datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString("en-GB", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </time>
            </div>
          </li>
        ))}
      </ul>
    ) : (
      <p class="mt-12 text-sm text-muted">No posts yet.</p>
    )}
  </section>
</Layout>
