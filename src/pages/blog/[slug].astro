---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const meta = post.data ?? {};
const title = meta.title ?? post.id;
const pub = meta.pubDate ? new Date(meta.pubDate) : undefined;
const { Content } = await render(post);
---

<Layout title={`${title} — Viktor Zouboulis`}>
  <article class="page-wrap py-16 sm:py-20">
    <p class="section-label mb-4">
      <a href="/blog" class="hover:text-accent">← blog</a>
    </p>

    <h1 class="text-3xl font-medium leading-tight text-ink sm:text-4xl dark:text-paper">
      {title}
    </h1>

    {pub && (
      <time class="mt-4 block text-sm text-muted" datetime={pub.toISOString()}>
        {pub.toLocaleDateString("en-GB", {
          year: "numeric",
          month: "long",
          day: "numeric",
        })}
      </time>
    )}

    {meta.description && (
      <p class="mt-6 text-base leading-relaxed text-muted">{meta.description}</p>
    )}

    <div class="rule mt-10"></div>

    <div class="prose prose-ink mt-10 max-w-none dark:prose-invert">
      <Content />
    </div>

    <div class="rule mt-16"></div>
    <footer class="mt-8 text-sm text-muted">
      <p class="text-ink dark:text-paper">Viktor Zouboulis</p>
      <p class="mt-1">Computational immunology</p>
    </footer>
  </article>
</Layout>
