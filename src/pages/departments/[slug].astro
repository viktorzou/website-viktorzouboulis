---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import { site } from "../../data/site";
import { formatAuthorsHtml } from "../../lib/authors";
import { extractDoi, getPaperMetricsByDois } from "../../lib/metrics";
import { collaboratorDepartments } from "../../lib/orgs";

export async function getStaticPaths() {
  const departments = await getCollection("departments");
  return departments.map((department) => ({
    params: { slug: department.id },
    props: { department },
  }));
}

const { department } = Astro.props;
const { Content } = await render(department);

const institutions = await getCollection("institutions");
const institution = institutions.find((i) => i.id === department.data.institution);

const labs = (await getCollection("labs"))
  .filter((l) => l.data.department === department.id)
  .sort((a, b) => a.data.order - b.data.order || a.data.name.localeCompare(b.data.name));

const people = (await getCollection("collaborators"))
  .filter((c) => collaboratorDepartments(c).includes(department.id))
  .sort((a, b) => a.data.order - b.data.order || a.data.name.localeCompare(b.data.name));

const projects = (await getCollection("projects"))
  .filter((p) => p.data.departments.includes(department.id))
  .sort((a, b) => (b.data.year ?? -1) - (a.data.year ?? -1));

const papers = (await getCollection("papers"))
  .filter((p) => p.data.departments.includes(department.id))
  .sort((a, b) => b.data.year - a.data.year);

const interesting = (await getCollection("interestingPapers"))
  .filter((p) => p.data.departments.includes(department.id))
  .sort((a, b) => b.data.year - a.data.year);

const paperMetrics = await getPaperMetricsByDois(
  [...papers, ...interesting]
    .map((p) => extractDoi(p.data.url))
    .filter((d): d is string => Boolean(d)),
);

const collaborators = await getCollection("collaborators");
function highlightAuthors(authors: string) {
  return formatAuthorsHtml(authors, collaborators);
}
---

<Layout title={`${department.data.short} — ${site.name}`}>
  <article class="page-wrap py-16 sm:py-20">
    <p class="section-label mb-4">
      <a href="/collaborators/#departments" class="hover:text-accent">← collaborators</a>
    </p>

    <p class="section-label mb-2">department</p>
    <h1 class="text-3xl font-medium leading-tight text-ink sm:text-4xl dark:text-paper">
      {department.data.name}
    </h1>

    <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-muted">
      {institution && (
        <a href={`/institutions/${institution.id}/`} class="text-accent hover:underline">
          {institution.data.short}
        </a>
      )}
      <span class="text-accent">{department.data.short}</span>
      {department.data.url && (
        <a
          href={department.data.url}
          class="link-accent"
          target="_blank"
          rel="noopener noreferrer"
        >
          website ↗
        </a>
      )}
    </div>

    {department.data.summary && (
      <p class="mt-6 text-base leading-relaxed text-muted">{department.data.summary}</p>
    )}

    <div class="rule mt-10"></div>

    <div class="prose prose-ink mt-10 max-w-none dark:prose-invert">
      <Content />
    </div>

    {labs.length > 0 && (
      <section id="labs" class="scroll-mt-20 pt-12">
        <p class="section-label mb-6">// labs</p>
        <ul>
          {labs.map((lab) => (
            <li class="border-b border-ink/10 py-5 first:border-t dark:border-paper/10">
              <h2 class="text-base font-medium text-ink dark:text-paper">
                <a href={`/labs/${lab.id}/`} class="hover:text-accent">
                  {lab.data.name}
                </a>
              </h2>
              {lab.data.summary && (
                <p class="mt-2 text-sm leading-relaxed text-muted">{lab.data.summary}</p>
              )}
            </li>
          ))}
        </ul>
      </section>
    )}

    {people.length > 0 && (
      <section id="people" class="scroll-mt-20 pt-12">
        <p class="section-label mb-6">// people</p>
        <ul>
          {people.map((person) => (
            <li class="border-b border-ink/10 py-5 first:border-t dark:border-paper/10">
              <h2 class="text-base font-medium text-ink dark:text-paper">
                <a href={`/collaborators/#${person.id}`} class="hover:text-accent">
                  {person.data.name}
                </a>
              </h2>
              <p class="mt-1 text-sm text-muted">{person.data.role}</p>
            </li>
          ))}
        </ul>
      </section>
    )}

    {projects.length > 0 && (
      <section id="projects" class="scroll-mt-20 pt-12">
        <p class="section-label mb-6">// projects</p>
        <ul>
          {projects.map((project) => (
            <li class="border-b border-ink/10 py-5 first:border-t dark:border-paper/10">
              <h2 class="text-base font-medium text-ink dark:text-paper">
                <a href={`/projects/${project.id}/`} class="hover:text-accent">
                  {project.data.title}
                </a>
              </h2>
              <p class="mt-2 text-sm leading-relaxed text-muted">{project.data.summary}</p>
            </li>
          ))}
        </ul>
      </section>
    )}

    {(papers.length > 0 || interesting.length > 0) && (
      <section id="papers" class="scroll-mt-20 pt-12">
        <p class="section-label mb-6">// papers</p>
        <ul>
          {[...papers, ...interesting].map((paper) => {
            const doi = extractDoi(paper.data.url);
            const paperStat = doi ? paperMetrics.get(doi) : undefined;
            const isInteresting = "note" in paper.data;
            return (
              <li class="border-b border-ink/10 py-6 first:border-t dark:border-paper/10">
                <div class="flex flex-col gap-2 sm:flex-row sm:items-baseline sm:justify-between sm:gap-12">
                  <div class="min-w-0 flex-1">
                    {isInteresting && (
                      <p class="section-label mb-2">interesting</p>
                    )}
                    <h2 class="text-base font-medium text-ink dark:text-paper">
                      {paper.data.url ? (
                        <a
                          href={paper.data.url}
                          class="hover:text-accent"
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          {paper.data.title}
                        </a>
                      ) : (
                        paper.data.title
                      )}
                    </h2>
                    <p
                      class="mt-1 text-sm leading-relaxed text-muted"
                      set:html={highlightAuthors(paper.data.authors)}
                    />
                    {"venue" in paper.data && paper.data.venue && (
                      <p class="mt-1 text-sm text-muted italic">{paper.data.venue}</p>
                    )}
                  </div>
                  <div class="flex w-20 shrink-0 flex-col items-start gap-2 text-sm text-muted sm:items-end">
                    <span>{paper.data.year}</span>
                    {paperStat && (
                      <span class="text-xs text-accent">cited {paperStat.citations}</span>
                    )}
                  </div>
                </div>
              </li>
            );
          })}
        </ul>
      </section>
    )}
  </article>
</Layout>
