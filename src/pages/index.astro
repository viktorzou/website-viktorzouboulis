---
import Layout from "../layouts/Layout.astro";
import TypewriterText from "../components/TypewriterText.tsx";
import { getCollection } from "astro:content";
import { site } from "../data/site";
import { departmentLabel, institutionLabel, labLabel } from "../lib/orgs";

const pinnedPapers = (await getCollection("papers"))
  .filter((p) => p.data.pinned)
  .sort((a, b) => b.data.year - a.data.year);

const pinnedProjects = (await getCollection("projects"))
  .filter((p) => p.data.pinned && p.data.track !== "commercial")
  .sort((a, b) => (b.data.year ?? -1) - (a.data.year ?? -1));

const pinnedWork = (await getCollection("projects"))
  .filter((p) => p.data.pinned && p.data.track === "commercial")
  .sort((a, b) => (b.data.year ?? -1) - (a.data.year ?? -1));

const pinnedPosts = (await getCollection("blog"))
  .filter((p) => !p.data.draft && p.data.pinned)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const pinnedPeople = (await getCollection("collaborators"))
  .filter((p) => p.data.pinned)
  .sort(
    (a, b) => a.data.order - b.data.order || a.data.name.localeCompare(b.data.name),
  );

const institutions = await getCollection("institutions");
const departments = await getCollection("departments");
const labs = await getCollection("labs");

const hasPinned =
  pinnedPapers.length > 0 ||
  pinnedProjects.length > 0 ||
  pinnedWork.length > 0 ||
  pinnedPosts.length > 0 ||
  pinnedPeople.length > 0;

function kindLabel(kind: string) {
  if (kind === "supervisor") return "supervisor";
  if (kind === "co-supervisor") return "co-supervisor";
  if (kind === "former-supervisor") return "former supervisor";
  if (kind === "student") return "student";
  return "collaborator";
}
---

<Layout title={site.name}>
  <section class="page-wrap flex min-h-[calc(100vh-7.5rem)] flex-col justify-center py-16 sm:py-24">
    <p class="section-label animate-fade-up mb-6">~/viktor</p>

    <h1 class="animate-fade-up text-4xl font-medium tracking-tight text-ink sm:text-5xl md:text-6xl dark:text-paper">
      {site.name}
    </h1>

    <p class="animate-fade-up-delay mt-6 text-lg sm:text-xl">
      <TypewriterText client:load />
    </p>

    <p class="animate-fade-up-delay-2 mt-8 max-w-xl text-base leading-relaxed text-muted">
      Medical student and researcher at the Centre for Human Genetics, University of Oxford —
      using knowledge graphs, machine learning, and patient data to understand inborn errors
      of immunity and inflammatory disease.
    </p>

    <div class="animate-fade-up-delay-2 mt-10 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm">
      <a href="/research" class="link-accent">→ research</a>
      <a href="/cv" class="link-accent">→ cv</a>
      <a href="/about" class="text-muted hover:text-accent">about</a>
      <a href="/blog" class="text-muted hover:text-accent">blog</a>
      <a href={`mailto:${site.email}`} class="link-accent">→ contact</a>
    </div>

    <p class="animate-fade-up-delay-2 mt-8 flex flex-wrap gap-x-3 gap-y-1 text-xs text-muted">
      {site.socials.map((social, i) => (
        <>
          {i > 0 && <span class="text-muted/40" aria-hidden="true">/</span>}
          <a
            href={social.href}
            class="hover:text-accent"
            target="_blank"
            rel="noopener noreferrer"
          >
            {social.label}
          </a>
        </>
      ))}
    </p>
  </section>

  {hasPinned && (
    <section class="page-wrap border-t border-ink/10 py-16 dark:border-paper/10">
      <p class="section-label mb-8">// selected</p>

      {pinnedPapers.length > 0 && (
        <div class="mb-12">
          <div class="mb-4 flex items-baseline justify-between gap-4">
            <h2 class="text-sm font-medium text-ink dark:text-paper">papers</h2>
            <a href="/research/#papers" class="text-xs text-muted hover:text-accent">all →</a>
          </div>
          <ul>
            {pinnedPapers.map((paper) => (
              <li class="is-pinned border-b border-ink/10 py-5 first:border-t dark:border-paper/10">
                <p class="section-label mb-2">pinned</p>
                <h3 class="text-base font-medium text-ink dark:text-paper">
                  {paper.data.url ? (
                    <a href={paper.data.url} class="hover:text-accent" target="_blank" rel="noopener noreferrer">
                      {paper.data.title}
                    </a>
                  ) : (
                    paper.data.title
                  )}
                </h3>
                <p class="mt-1 text-sm text-muted italic">{paper.data.venue} · {paper.data.year}</p>
                {paper.data.blog && (
                  <p class="mt-2 text-sm">
                    <a href={`/blog/${paper.data.blog}/`} class="link-accent">→ read more</a>
                  </p>
                )}
              </li>
            ))}
          </ul>
        </div>
      )}

      {pinnedProjects.length > 0 && (
        <div class="mb-12">
          <div class="mb-4 flex items-baseline justify-between gap-4">
            <h2 class="text-sm font-medium text-ink dark:text-paper">projects</h2>
            <a href="/research/#projects" class="text-xs text-muted hover:text-accent">all →</a>
          </div>
          <ul>
            {pinnedProjects.map((project) => (
              <li class="is-pinned border-b border-ink/10 py-5 first:border-t dark:border-paper/10">
                <p class="section-label mb-2">
                  {[
                    "pinned",
                    project.data.status === "planned" && "planned",
                    project.data.review && "review / opinion",
                    project.data.stealth &&
                      (project.data.status === "planned"
                        ? "stealth"
                        : "building in stealth"),
                  ]
                    .filter(Boolean)
                    .join(" · ")}
                </p>
                <h3 class="text-base font-medium text-ink dark:text-paper">
                  <a href={`/projects/${project.id}/`} class="hover:text-accent">
                    {project.data.title}
                  </a>
                </h3>
                <p class="mt-2 text-sm leading-relaxed text-muted">{project.data.summary}</p>
              </li>
            ))}
          </ul>
        </div>
      )}

      {pinnedWork.length > 0 && (
        <div class="mb-12">
          <div class="mb-4 flex items-baseline justify-between gap-4">
            <h2 class="text-sm font-medium text-ink dark:text-paper">work</h2>
            <a href="/work/" class="text-xs text-muted hover:text-accent">all →</a>
          </div>
          <ul>
            {pinnedWork.map((project) => (
              <li class="is-pinned border-b border-ink/10 py-5 first:border-t dark:border-paper/10">
                <p class="section-label mb-2">
                  {[
                    "pinned",
                    project.data.status === "planned" && "planned",
                    project.data.review && "review / opinion",
                    project.data.stealth &&
                      (project.data.status === "planned"
                        ? "stealth"
                        : "building in stealth"),
                  ]
                    .filter(Boolean)
                    .join(" · ")}
                </p>
                <h3 class="text-base font-medium text-ink dark:text-paper">
                  <a href={`/projects/${project.id}/`} class="hover:text-accent">
                    {project.data.title}
                  </a>
                </h3>
                <p class="mt-2 text-sm leading-relaxed text-muted">{project.data.summary}</p>
              </li>
            ))}
          </ul>
        </div>
      )}

      {pinnedPeople.length > 0 && (
        <div class="mb-12">
          <div class="mb-4 flex items-baseline justify-between gap-4">
            <h2 class="text-sm font-medium text-ink dark:text-paper">people</h2>
            <a href="/collaborators/" class="text-xs text-muted hover:text-accent">all →</a>
          </div>
          <ul>
            {pinnedPeople.map((person) => (
              <li class="is-pinned border-b border-ink/10 py-5 first:border-t dark:border-paper/10">
                <p class="section-label mb-2">
                  {[
                    "pinned",
                    kindLabel(person.data.kind),
                  ].join(" · ")}
                </p>
                <h3 class="text-base font-medium text-ink dark:text-paper">
                  <a href={`/collaborators/#${person.id}`} class="hover:text-accent">
                    {person.data.name}
                  </a>
                </h3>
                <p class="mt-1 text-sm text-muted">
                  {person.data.institution && (
                    <a
                      href={`/institutions/${person.data.institution}/`}
                      class="hover:text-accent"
                    >
                      {institutionLabel(person.data.institution, institutions)}
                    </a>
                  )}
                  {person.data.institution && person.data.department && (
                    <span class="mx-2 text-muted/40">·</span>
                  )}
                  {person.data.department && (
                    <a
                      href={`/departments/${person.data.department}/`}
                      class="hover:text-accent"
                    >
                      {departmentLabel(person.data.department, departments)}
                    </a>
                  )}
                  {(person.data.institution || person.data.department) &&
                    person.data.lab && <span class="mx-2 text-muted/40">·</span>}
                  {person.data.lab && (
                    <a href={`/labs/${person.data.lab}/`} class="hover:text-accent">
                      {labLabel(person.data.lab, labs)}
                    </a>
                  )}
                </p>
              </li>
            ))}
          </ul>
        </div>
      )}

      {pinnedPosts.length > 0 && (
        <div>
          <div class="mb-4 flex items-baseline justify-between gap-4">
            <h2 class="text-sm font-medium text-ink dark:text-paper">writing</h2>
            <a href="/blog/" class="text-xs text-muted hover:text-accent">all →</a>
          </div>
          <ul>
            {pinnedPosts.map((post) => (
              <li class="is-pinned border-b border-ink/10 py-5 first:border-t dark:border-paper/10">
                <p class="section-label mb-2">pinned</p>
                <h3 class="text-base font-medium text-ink dark:text-paper">
                  <a href={`/blog/${post.id}/`} class="hover:text-accent">{post.data.title}</a>
                </h3>
                {post.data.description && (
                  <p class="mt-2 text-sm leading-relaxed text-muted">{post.data.description}</p>
                )}
              </li>
            ))}
          </ul>
        </div>
      )}
    </section>
  )}
</Layout>
