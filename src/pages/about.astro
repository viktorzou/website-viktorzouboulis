---
import Layout from "../layouts/Layout.astro";
import { site } from "../data/site";

const hobbies = [
  {
    label: "rowing",
    detail:
      "I row for Christ Church College — on the Isis or in Sandford when the river cooperates.",
  },
  {
    label: "cycling",
    detail:
      "Cycling around Oxford and further afield — a reliable way to clear the head between long days at the computer.",
  },
  {
    label: "sailing",
    detail:
      "I compete for the University sailing team and have completed offshore races including the Fastnet. Member of Berliner Yacht-Club, Akademischer Segler-Verein Hamburg, Oxford University Yachting Club, and the Royal Ocean Racing Club (RORC). I crossed the Atlantic in 2017. I previously sailed the second German Bundesliga in J/70s, and before that H-Boats and J/24s.",
  },
  {
    label: "community",
    detail:
      "I lead the KAS scholarship holder group in Oxford and serve on the committee of the Oxford German Society as Alumni Officer. In the Partnership team of the German British Conference (GBC), I act as lead responsible for outreach to German foundations.",
  },
  {
    label: "table tennis",
    detail:
      "Always up for a match — collaborations and conversations are welcome over coffee, in a pub, or across a table tennis table.",
  },
  {
    label: "techno",
    detail:
      "Retired techno DJ — played major clubs in Hamburg and a few festivals across Germany.",
  },
];
---

<Layout title={`About — ${site.name}`}>
  <section class="page-wrap py-16 sm:py-20">
    <p class="section-label mb-4">03 — about</p>
    <h1 class="text-3xl font-medium text-ink sm:text-4xl dark:text-paper">About</h1>

    <div class="mt-10 space-y-6 text-base leading-relaxed text-muted">
      <p>
        I'm a German-Greek medical student and researcher based at the
        <a
          href={site.oxfordProfile}
          class="link-accent"
          target="_blank"
          rel="noopener noreferrer"
        >Centre for Human Genetics</a>, University of Oxford, working with the Uhlig and
        Dendrou labs. I'm also affiliated with the University Medical Center
        Hamburg-Eppendorf (UKE), and previously trained at Semmelweis University and
        TU Berlin.
      </p>
      <p>
        My work focuses on computational immunology — using knowledge graphs, machine
        learning, and patient data to find structure in complex biomedical datasets and
        improve the understanding and classification of inborn errors of immunity and
        inflammatory diseases such as IBD. I care about translating those insights into
        clinically useful applications.
      </p>
      <p>
        Outside the lab, rowing for Christ Church, cycling, sailing, community work, the
        odd game of table tennis, and a former life as a techno DJ keep things balanced.
        Feel free to reach out.
      </p>
    </div>

    <div class="rule mt-12"></div>

    <section class="pt-12">
      <p class="section-label mb-6">// outside the lab</p>
      <ul>
        {hobbies.map((hobby) => (
          <li class="border-b border-ink/10 py-6 first:border-t dark:border-paper/10">
            <h2 class="text-sm font-medium text-accent">{hobby.label}</h2>
            <p class="mt-2 text-sm leading-relaxed text-muted">{hobby.detail}</p>
          </li>
        ))}
      </ul>
    </section>

    <section class="pt-12">
      <p class="section-label mb-6">// connect</p>
      <ul class="border-t border-ink/10 dark:border-paper/10">
        <li class="border-b border-ink/10 py-4 dark:border-paper/10">
          <span class="text-sm text-muted">email</span>
          <a href={`mailto:${site.email}`} class="link-accent ml-4 text-sm">{site.email}</a>
        </li>
        {site.socials.map((social) => (
          <li class="border-b border-ink/10 py-4 dark:border-paper/10">
            <span class="text-sm text-muted">{social.label}</span>
            <a
              href={social.href}
              class="link-accent ml-4 text-sm"
              target="_blank"
              rel="noopener noreferrer"
            >
              {social.href.replace(/^https?:\/\/(www\.)?/, "")}
            </a>
          </li>
        ))}
      </ul>
    </section>
  </section>
</Layout>
