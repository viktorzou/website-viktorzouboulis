---
import "../styles/tailwind.css";
import { site } from "../data/site";

type Props = {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  /** Absolute canonical URL; defaults to site.url + pathname */
  canonical?: string;
};

const {
  title = site.title,
  description = site.description,
  ogTitle = title,
  ogDescription = description,
  ogType = "website",
  canonical: canonicalProp,
} = Astro.props as Props;

const pathname = Astro.url.pathname;
const canonical =
  canonicalProp ??
  new URL(pathname === "/" ? "/" : pathname.replace(/\/?$/, "/"), `${site.url}/`)
    .href;

const links = [
  { href: "/", label: "home" },
  { href: "/research", label: "research" },
  { href: "/work", label: "work" },
  { href: "/collaborators", label: "collaborators" },
  { href: "/cv", label: "cv" },
  { href: "/tags", label: "tags" },
  { href: "/about", label: "about" },
  { href: "/blog", label: "blog" },
];

function isActive(href: string) {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}
---

<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={site.name} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script is:inline>
      const saved = localStorage.getItem("theme");
      // Dark is the default; only light when explicitly chosen.
      if (saved !== "light") {
        document.documentElement.classList.add("dark");
      }
    </script>
  </head>
  <body class="flex min-h-full flex-col bg-grid text-ink dark:text-paper">
    <header class="sticky top-0 z-50 border-b border-ink/10 bg-paper/90 backdrop-blur-sm dark:border-paper/10 dark:bg-charcoal/90">
      <div class="mx-auto flex h-14 max-w-4xl items-center justify-between gap-4 px-4 sm:px-6">
        <a href="/" class="shrink-0 text-sm font-medium text-ink hover:text-accent dark:text-paper">
          vz
        </a>

        <nav class="hidden items-center gap-1 text-sm md:flex" aria-label="Main">
          {links.map((link, i) => (
            <>
              {i > 0 && <span class="text-muted/50 select-none" aria-hidden="true">/</span>}
              <a
                href={link.href}
                class:list={[
                  "px-1.5 py-0.5 hover:text-accent",
                  isActive(link.href) ? "text-accent" : "text-muted",
                ]}
              >
                {link.label}
              </a>
            </>
          ))}
        </nav>

        <div class="flex items-center gap-2">
          <a
            href={`mailto:${site.email}`}
            class="border border-ink/15 px-2 py-1 text-xs text-muted hover:border-accent hover:text-accent dark:border-paper/15"
          >
            contact
          </a>
          <button
            type="button"
            class="border border-ink/15 px-2 py-1 text-xs text-muted hover:border-accent hover:text-accent dark:border-paper/15"
            onclick="
              const root = document.documentElement;
              root.classList.toggle('dark');
              localStorage.setItem('theme', root.classList.contains('dark') ? 'dark' : 'light');
            "
            aria-label="Toggle theme"
          >
            theme
          </button>

          <button
            type="button"
            id="menu-toggle"
            class="border border-ink/15 px-2 py-1 text-xs text-muted hover:border-accent hover:text-accent md:hidden dark:border-paper/15"
            aria-expanded="false"
            aria-controls="mobile-nav"
            aria-label="Open menu"
          >
            menu
          </button>
        </div>
      </div>

      <nav
        id="mobile-nav"
        class="hidden border-t border-ink/10 px-4 py-3 md:hidden dark:border-paper/10"
        aria-label="Mobile"
      >
        <ul class="flex flex-col gap-2 text-sm">
          {links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  "block py-1 hover:text-accent",
                  isActive(link.href) ? "text-accent" : "text-muted",
                ]}
              >
                {link.label}
              </a>
            </li>
          ))}
          <li>
            <a href={`mailto:${site.email}`} class="block py-1 text-accent">
              contact
            </a>
          </li>
        </ul>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-ink/10 dark:border-paper/10">
      <div class="page-wrap-wide flex flex-col gap-4 py-6 text-xs text-muted sm:flex-row sm:items-center sm:justify-between">
        <p>
          <span class="text-ink dark:text-paper">{site.name}</span>
          <span class="mx-2 text-muted/40">·</span>
          <a href={`mailto:${site.email}`} class="link-accent">{site.email}</a>
        </p>
        <nav class="flex flex-wrap items-center gap-x-3 gap-y-1" aria-label="Social">
          {site.socials.map((social, i) => (
            <>
              {i > 0 && <span class="text-muted/40" aria-hidden="true">/</span>}
              <a
                href={social.href}
                class="hover:text-accent"
                target="_blank"
                rel="noopener noreferrer"
              >
                {social.label}
              </a>
            </>
          ))}
          <span class="text-muted/40" aria-hidden="true">·</span>
          <span>© {new Date().getFullYear()}</span>
        </nav>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById("menu-toggle");
      const nav = document.getElementById("mobile-nav");
      toggle?.addEventListener("click", () => {
        const open = nav?.classList.toggle("hidden") === false;
        toggle.setAttribute("aria-expanded", String(open));
        toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
        toggle.textContent = open ? "close" : "menu";
      });
    </script>
  </body>
</html>
